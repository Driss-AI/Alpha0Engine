# ============================================
# Alpha0Engine — Environment Variables
# ============================================
# Copy to .env — NEVER commit .env to GitHub.

# DATABASE (Railway injects automatically)
DATABASE_URL=postgresql://postgres:password@localhost:5432/alpha_engine

# REDIS (Railway injects automatically)
REDIS_URL=redis://localhost:6379/0

# CLOUDFLARE R2
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=alpha-engine-raw

# SEC EDGAR (use real email — EDGAR Fair Access Policy)
EDGAR_USER_AGENT=Alpha0Engine contact@yourdomain.com

# USPTO PATENTSVIEW (free: https://patentsview.org/apis/api-endpoints/)
PATENTSVIEW_API_KEY=your_patentsview_api_key

# GITHUB (read:org, read:user, public_repo scopes)
GITHUB_TOKEN=your_github_personal_access_token

# FINNHUB (free tier: https://finnhub.io/) — used by ingest-news
FINNHUB_API_KEY=

# WORKER RUN MODE (loop for dev/compose, once for Railway cron)
RUN_MODE=loop

# PAID SOURCES (configure when contracted)
PITCHBOOK_API_KEY=
CBINSIGHTS_API_KEY=
CAPLIGHT_API_KEY=

# APP
ENVIRONMENT=development
LOG_LEVEL=INFO

# AUTH — TWO SEPARATE KEYS, REQUIRED IN PROD
# API_SECRET_KEY = admin / write key. NEVER embed in HTML or client-side code.
# VIEWER_API_KEY = read-only key, safe to expose in dashboard HTML.
# Generate two distinct random strings, e.g. `python3 -c "import secrets; print(secrets.token_urlsafe(32))"`
API_SECRET_KEY=change-this-to-a-long-random-string
VIEWER_API_KEY=change-this-to-a-different-long-random-string

# CORS (comma-separated origins, leave empty for dev wildcard)
ALLOWED_ORIGINS=

# RATE LIMITING (slowapi format: "60/minute", "100/hour")
RATE_LIMIT=60/minute
